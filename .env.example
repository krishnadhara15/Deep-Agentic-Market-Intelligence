# ===== LLM provider: gemini (recommended, free), openai, or tavily (no LLM) =====
LLM_PROVIDER=gemini

# Required for all modes
TAVILY_API_KEY=your_tavily_api_key_here

# Required if LLM_PROVIDER=gemini  (free key: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here

# ===== Model configuration =====
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_REPORT=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_REPORT=gpt-4o

# ===== Research target (defaults to the P&G case study) =====
TARGET=Procter & Gamble (P&G)
CATEGORIES=personal care,grooming,oral care,household cleaning,baby care,beauty
LANGUAGES=English

# ===== Orchestration tunables =====
MAX_LOOPS=2
MAX_BRANCHES=6
SEARCHES_PER_QUESTION=3
MAX_SUB_QUESTIONS=6

# ===== Signal-vs-noise detection (0.0 - 1.0) =====
SIGNAL_THRESHOLD=0.5

# ===== Multi-source retrieval: community/review/forum domains =====
COMMUNITY_DOMAINS=reddit.com,trustpilot.com,influenster.com,quora.com,youtube.com

# ===== Sequential-thinking MCP server (records the verifier's reasoning chain) =====
USE_MCP_SEQUENTIAL_THINKING=true

# ===== Statistical signal detection: weight blended with the LLM/reasoning score =====
STATISTICAL_WEIGHT=0.4

# ===== Heterogeneous internal data sources =====
INTERNAL_DATA_DIR=data/internal

# ===== Perception-over-time history (persisted across runs) =====
PERCEPTION_HISTORY_PATH=outputs/perception_history.json

# ===== Optional: LangSmith tracing =====
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=deep-agentic-market-intel
